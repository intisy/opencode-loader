{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext",
    "target": "esnext",
    "sourceMap": true,
    "declaration": true,
    "strict": false,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["esnext"]
  },
  "include": ["src/**/*"]
}